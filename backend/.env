# ─────────────────────────────────────────────────────────────────────────────
# Firduty Backend — Environment Variables
# Copy this file to .env for local development.
# In production (Koyeb), set these directly as platform environment variables.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED in production) ─────────────────────────────────────────
# Supabase connection string format:
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.szbcfletjkmdgfpcpmbs.supabase.co:5432/postgres

# ── JWT (REQUIRED in production) ──────────────────────────────────────────────
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Admin Credentials (REQUIRED in production) ────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ── Firebase (optional — push notifications disabled if missing) ───────────────
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── Server (optional — Koyeb injects PORT automatically) ──────────────────────
PORT=8000

# ── CORS (optional — defaults to * for local dev) ─────────────────────────────
# Set to your actual admin UI domain in production (comma-separated):
# ALLOWED_ORIGINS=https://admin.yourschool.com,https://yourschool.com
ALLOWED_ORIGINS=*
