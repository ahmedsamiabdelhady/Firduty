{
  "pythonVersion": "3.11",
  "pythonPlatform": "Windows",
  "include": [
    "backend"
  ],
  "extraPaths": [
    "backend",
    "backend/jobs"
  ],
  "typeCheckingMode": "basic",
  "reportMissingImports": "warning",
  "reportMissingModuleSource": "none",
  "reportMissingModuleSourceFiles": "none",
  "executionEnvironments": [
    {
      "root": "backend",
      "pythonVersion": "3.11",
      "extraPaths": ["backend", "backend/jobs"]
    },
    {
      "root": "backend/jobs",
      "pythonVersion": "3.11",
      "extraPaths": ["backend", "backend/jobs"]
    }
  ]
}